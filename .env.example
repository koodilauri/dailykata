# Supabase Postgres — use the transaction pooler URL (port 6543, PgBouncer)
DATABASE_URL=postgres://postgres.[ref]:[password]@pooler.supabase.com:6543/postgres?pgBouncer=true
DIRECT_DATABASE_URL=

# GitHub OAuth app (Settings > Developer settings > OAuth Apps)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Local dev
BETTER_AUTH_URL=http://localhost:3000
VITE_BETTER_AUTH_URL=http://localhost:3000
